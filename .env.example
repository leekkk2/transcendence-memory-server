# transcendence-memory-server 环境变量模板

# 服务端 API 认证密钥
RAG_API_KEY=your-rag-api-key

# Embedding 配置
EMBEDDING_BASE_URL=https://newapi.zweiteng.tk/v1
EMBEDDING_API_KEY=sk-your-api-key
EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIM=3072

# LLM 配置
LLM_MODEL=gemini-2.5-flash
LLM_BASE_URL=https://newapi.zweiteng.tk/v1
LLM_API_KEY=sk-your-api-key

# VLM（视觉语言模型）配置
VLM_MODEL=qwen3-vl-plus
VLM_BASE_URL=https://newapi.zweiteng.tk/v1
VLM_API_KEY=sk-your-api-key

# 对外暴露的 endpoint（用于 connection token 生成）
RAG_ADVERTISED_ENDPOINT=http://localhost:8711

# 工作区目录（Docker 中默认 /data）
WORKSPACE=/data
